#!/bin/bash
# glab 包装脚本
# 如果智能体工作目录下存在 gitlab-cli.conf 目录，直接将其作为 GLAB_CONFIG_DIR
# 否则从默认配置目录复制一份到工作目录下

REAL_GLAB=/home/linuxbrew/.linuxbrew/bin/glab
DEFAULT_GLAB_DIR="$HOME/.config/glab-cli"
WORKSPACE_GLAB_DIR="$PWD/gitlab-cli.conf"

if [ ! -d "$WORKSPACE_GLAB_DIR" ]; then
    if [ -d "$DEFAULT_GLAB_DIR" ]; then
        cp -r "$DEFAULT_GLAB_DIR" "$WORKSPACE_GLAB_DIR"
    else
        mkdir -p "$WORKSPACE_GLAB_DIR"
    fi
fi

GLAB_CONFIG_DIR="$WORKSPACE_GLAB_DIR" exec "$REAL_GLAB" "$@"